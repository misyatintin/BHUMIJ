<%- include('../partials/admin-header') %>
<% if (success) { %><div class="alert alert-success"><span class="material-symbols-outlined">check_circle</span> Saved successfully!</div><% } %>

<div class="form-card">
    <h3 id="formTitle">Add Etymology Card</h3>
    <form action="/admin/etymology/save" method="POST">
        <input type="hidden" name="id" id="cardId">
        <div class="form-grid">
            <div class="form-group">
                <label>Material Icon Name</label>
                <input type="text" name="icon" id="cardIcon" required placeholder="e.g. landscape">
            </div>
            <div class="form-group">
                <label>Sort Order</label>
                <input type="number" name="sort_order" id="cardOrder" value="0">
            </div>
            <div class="form-group">
                <label>Title (EN)</label>
                <input type="text" name="title_en" id="cardTitleEn" required>
            </div>
            <div class="form-group">
                <label>Title (BN)</label>
                <input type="text" name="title_bn" id="cardTitleBn" required>
            </div>
        </div>
        <div class="form-group">
            <label>Content (EN)</label>
            <textarea name="content_en" id="cardContentEn" rows="3" required></textarea>
        </div>
        <div class="form-group">
            <label>Content (BN)</label>
            <textarea name="content_bn" id="cardContentBn" rows="3" required></textarea>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary" id="saveBtn">Save Card</button>
            <button type="button" class="btn" onclick="resetForm()" style="display:none;" id="cancelBtn">Cancel</button>
        </div>
    </form>
</div>

<div class="action-bar">
    <h3 style="font-size:16px;color:#64748b;">Existing Etymology Cards</h3>
</div>

<table class="data-table">
    <thead>
        <tr>
            <th>Icon</th>
            <th>Title (EN)</th>
            <th>Title (BN)</th>
            <th>Sort Order</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        <% cards.forEach(c => { %>
        <tr>
            <td><span class="material-symbols-outlined"><%= c.icon %></span></td>
            <td><strong><%= c.title_en %></strong></td>
            <td><%= c.title_bn %></td>
            <td><%= c.sort_order %></td>
            <td>
                <button class="btn btn-sm btn-primary edit-btn" data-info='<%- JSON.stringify(c) %>'>Edit</button>
                <a href="/admin/etymology/delete/<%= c.id %>" class="btn btn-sm btn-danger" onclick="return confirm('Delete this card?')">Delete</a>
            </td>
        </tr>
        <% }) %>
    </tbody>
</table>

<script>
document.querySelectorAll('.edit-btn').forEach(btn => {
    btn.addEventListener('click', function() {
        const card = JSON.parse(this.dataset.info);
        document.getElementById('formTitle').innerText = 'Edit Etymology Card';
        document.getElementById('cardId').value = card.id;
        document.getElementById('cardIcon').value = card.icon;
        document.getElementById('cardOrder').value = card.sort_order;
        document.getElementById('cardTitleEn').value = card.title_en;
        document.getElementById('cardTitleBn').value = card.title_bn;
        document.getElementById('cardContentEn').value = card.content_en;
        document.getElementById('cardContentBn').value = card.content_bn;
        document.getElementById('saveBtn').innerText = 'Update Card';
        document.getElementById('cancelBtn').style.display = 'inline-block';
        window.scrollTo({ top: 0, behavior: 'smooth' });
    });
});

function resetForm() {
    document.getElementById('formTitle').innerText = 'Add Etymology Card';
    document.getElementById('cardId').value = '';
    document.getElementById('cardIcon').value = '';
    document.getElementById('cardOrder').value = '0';
    document.getElementById('cardTitleEn').value = '';
    document.getElementById('cardTitleBn').value = '';
    document.getElementById('cardContentEn').value = '';
    document.getElementById('cardContentBn').value = '';
    document.getElementById('saveBtn').innerText = 'Save Card';
    document.getElementById('cancelBtn').style.display = 'none';
}
</script>

<%- include('../partials/admin-footer') %>
