<%- include('../partials/admin-header') %>
<% if (success) { %><div class="alert alert-success"><span class="material-symbols-outlined">check_circle</span> Saved!</div><% } %>

<!-- Upload Slide -->
<div class="form-card">
    <h3>Add Hero Slide</h3>
    <form method="POST" action="/admin/slides/save" enctype="multipart/form-data">
        <div class="form-row">
            <div class="form-group"><label>Title (English)</label><input type="text" name="title_en"></div>
            <div class="form-group"><label>Title (Bengali)</label><input type="text" name="title_bn"></div>
        </div>
        <div class="form-row">
            <div class="form-group"><label>Subtitle (English)</label><input type="text" name="subtitle_en"></div>
            <div class="form-group"><label>Subtitle (Bengali)</label><input type="text" name="subtitle_bn"></div>
        </div>
        <div class="form-row">
            <div class="form-group"><label>Image</label><input type="file" name="image" accept="image/*" required></div>
            <div class="form-group"><label>Sort Order</label><input type="number" name="sort_order" value="0"></div>
        </div>
        <button type="submit" class="btn btn-primary"><span class="material-symbols-outlined">upload</span> Add Slide</button>
    </form>
</div>

<!-- Existing Slides -->
<div class="form-card">
    <h3>Current Slides (<%= slides.length %>)</h3>
    <div class="gallery-grid">
        <% slides.forEach(s => { %>
        <div class="gallery-item">
            <img src="/uploads/<%= s.image_path %>" alt="<%= s.title_en %>">
            <div class="overlay"><a href="/admin/slides/delete/<%= s.id %>" class="btn btn-sm btn-danger" onclick="return confirm('Delete?')" style="background:#ef4444;color:#fff">Delete</a></div>
        </div>
        <% }) %>
    </div>
</div>
<%- include('../partials/admin-footer') %>
