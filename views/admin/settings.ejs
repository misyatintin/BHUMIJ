<%- include('../partials/admin-header') %>
<% if (success) { %><div class="alert alert-success"><span class="material-symbols-outlined">check_circle</span> Saved!</div><% } %>
<div class="form-card">
    <h3>Site Settings (Bilingual)</h3>
    <form method="POST" action="/admin/settings/save" enctype="multipart/form-data">
        <% settings.forEach(s => { %>
        <div class="form-group" style="background:#f8fafc;padding:24px;border-radius:16px;border:1px solid #e2e8f0;margin-bottom:24px;">
            <label style="font-size:14px; margin-bottom:16px;"><%= s.setting_key.replace(/_/g, ' ') %></label>
            <input type="hidden" name="keys" value="<%= s.setting_key %>">
            
            <% if (s.setting_key === 'site_logo' || s.setting_key === 'site_favicon') { %>
                <div class="form-grid">
                    <% if (s.setting_value_en) { %>
                        <div>
                            <small>Current Image:</small>
                            <div style="margin-top:8px; padding:10px; background:#fff; border:1px solid #e2e8f0; border-radius:10px; display:inline-block;">
                                <img src="/uploads/<%= s.setting_value_en %>" style="max-height: 40px; display:block;">
                            </div>
                        </div>
                    <% } %>
                    <div>
                        <small>Upload New:</small>
                        <input type="file" name="<%= s.setting_key %>" accept="image/*" style="margin-top:8px;">
                    </div>
                </div>
            <% } else { %>
                <div class="form-row">
                    <div class="form-group" style="margin-bottom:0">
                        <small>English</small>
                        <textarea name="values_en" rows="2" style="min-height:80px; margin-top:8px;"><%= s.setting_value_en %></textarea>
                    </div>
                    <div class="form-group" style="margin-bottom:0">
                        <small>Bengali</small>
                        <textarea name="values_bn" rows="2" style="min-height:80px; margin-top:8px;"><%= s.setting_value_bn %></textarea>
                    </div>
                </div>
            <% } %>
        </div>
        <% }) %>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary" style="flex:none; padding-left:40px; padding-right:40px;">
                <span class="material-symbols-outlined">save</span> Save All Settings
            </button>
        </div>
    </form>
</div>
<%- include('../partials/admin-footer') %>
