<%- include('../partials/admin-header') %>
<% if (success) { %><div class="alert alert-success"><span class="material-symbols-outlined">check_circle</span> Saved successfully!</div><% } %>

<div class="form-card">
    <h3 id="formTitle">Add Tour Activity</h3>
    <form action="/admin/tours/save" method="POST">
        <input type="hidden" name="id" id="tourId">
        <div class="form-grid">
            <div class="form-group">
                <label>Title (EN)</label>
                <input type="text" name="title_en" id="tourTitleEn" required>
            </div>
            <div class="form-group">
                <label>Title (BN)</label>
                <input type="text" name="title_bn" id="tourTitleBn" required>
            </div>
            <div class="form-group">
                <label>Sort Order</label>
                <input type="number" name="sort_order" id="tourOrder" value="0">
            </div>
        </div>
        <div class="form-group">
            <label>Description (EN)</label>
            <div id="editor-en" style="height: 150px; background: white;"><%- '' %></div>
            <input type="hidden" name="description_en" id="description_en">
        </div>
        <div class="form-group">
            <label>Description (BN)</label>
            <div id="editor-bn" style="height: 150px; background: white;"><%- '' %></div>
            <input type="hidden" name="description_bn" id="description_bn">
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary" id="saveBtn">Save Activity</button>
            <button type="button" class="btn" onclick="resetForm()" style="display:none;" id="cancelBtn">Cancel</button>
        </div>
    </form>
</div>

<div class="action-bar">
    <h3 style="font-size:16px;color:#64748b;">Current Tour Activities</h3>
</div>

<table class="data-table">
    <thead>
        <tr>
            <th>Title (EN)</th>
            <th>Title (BN)</th>
            <th>Sort</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        <% tours.forEach(t => { %>
        <tr>
            <td><strong><%= t.title_en %></strong></td>
            <td><%= t.title_bn %></td>
            <td><%= t.sort_order %></td>
            <td>
                <button class="btn btn-sm btn-primary edit-btn" data-info='<%- JSON.stringify(t) %>'>Edit</button>
                <a href="/admin/tours/delete/<%= t.id %>" class="btn btn-sm btn-danger" onclick="return confirm('Delete this activity?')">Delete</a>
            </td>
        </tr>
        <% }) %>
    </tbody>
</table>

<script>
var quillEn = new Quill('#editor-en', { theme: 'snow', modules: { toolbar: [['bold', 'italic', 'underline'], [{ 'list': 'ordered'}, { 'list': 'bullet' }], ['clean']] } });
var quillBn = new Quill('#editor-bn', { theme: 'snow', modules: { toolbar: [['bold', 'italic', 'underline'], [{ 'list': 'ordered'}, { 'list': 'bullet' }], ['clean']] } });

document.querySelector('form').onsubmit = function() {
    document.getElementById('description_en').value = quillEn.root.innerHTML;
    document.getElementById('description_bn').value = quillBn.root.innerHTML;
};

document.querySelectorAll('.edit-btn').forEach(btn => {
    btn.addEventListener('click', function() {
        const t = JSON.parse(this.dataset.info);
        document.getElementById('formTitle').innerText = 'Edit Tour Activity';
        document.getElementById('tourId').value = t.id;
        document.getElementById('tourTitleEn').value = t.title_en;
        document.getElementById('tourTitleBn').value = t.title_bn;
        document.getElementById('tourOrder').value = t.sort_order;
        quillEn.root.innerHTML = t.description_en || '';
        quillBn.root.innerHTML = t.description_bn || '';
        document.getElementById('saveBtn').innerText = 'Update Activity';
        document.getElementById('cancelBtn').style.display = 'inline-block';
        window.scrollTo({ top: 0, behavior: 'smooth' });
    });
});

function resetForm() {
    document.getElementById('formTitle').innerText = 'Add Tour Activity';
    document.getElementById('tourId').value = '';
    document.getElementById('tourTitleEn').value = '';
    document.getElementById('tourTitleBn').value = '';
    document.getElementById('tourOrder').value = '0';
    quillEn.root.innerHTML = '';
    quillBn.root.innerHTML = '';
    document.getElementById('saveBtn').innerText = 'Save Activity';
    document.getElementById('cancelBtn').style.display = 'none';
}
</script>

<%- include('../partials/admin-footer') %>
