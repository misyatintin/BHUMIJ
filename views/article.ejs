<%- include('partials/header') %>


<section class="pt-32 pb-24 px-6">
    <div class="max-w-3xl mx-auto">
        <div class="inline-block px-4 py-1.5 bg-blue-50 rounded-full text-[10px] font-bold text-primary uppercase tracking-widest mb-6"><%= article.article_type %></div>
        <h1 class="cinzel-font text-3xl md:text-5xl font-black text-dark-slate mb-6 leading-tight"><%= t(article, 'title', lang) %></h1>
        <% if (article.author_en || article.author_bn) { %>
        <p class="text-primary font-bold text-sm uppercase tracking-widest mb-8"><%= lang === 'bn' ? 'লেখক: ' : 'By: ' %><%= t(article, 'author', lang) %></p>
        <% } %>
        <% if (article.image_path) { %>
        <div class="rounded-[30px] overflow-hidden mb-10 shadow-xl"><img src="/uploads/<%= article.image_path %>" alt="" class="w-full"></div>
        <% } %>
        <div class="text-slate-600 text-lg leading-[2] font-light whitespace-pre-line"><%= t(article, 'content', lang) %></div>
        <div class="mt-12 pt-8 border-t border-slate-100">
            <a href="/" class="inline-flex items-center gap-2 text-primary font-bold hover:gap-4 transition-all">
                <span class="material-symbols-outlined">arrow_back</span>
                <%= lang === 'bn' ? 'প্রচ্ছদে ফিরে যান' : 'Back to Home' %>
            </a>
        </div>
    </div>
</section>

<%- include('partials/footer') %>

