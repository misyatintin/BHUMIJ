        <p style="font-size:20px;color:var(--text-muted);margin-bottom:32px;">Page Not Found</p>
        <a href="/" style="display:inline-flex;align-items:center;gap:8px;padding:14px 28px;background:#3b82f6;color:#fff;border-radius:12px;font-weight:600;">← Go Home</a>
    </div>
