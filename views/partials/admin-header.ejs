<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Bhumij CMS</title>
    <% if (typeof settingsMap !== 'undefined' && settingsMap.site_favicon && settingsMap.site_favicon.en) { %>
        <link rel="icon" type="image/x-icon" href="/uploads/<%= settingsMap.site_favicon.en %>">
    <% } %>
    <link rel="icon" type="image/png" href="/uploads/<%= settingsMap.site_favicon?.en || 'favicon.png' %>">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/admin.css">
    <!-- Quill Rich Text Editor (Free) -->
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
    <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
</head>
<body>
    <div class="admin-wrapper">
        <style>
        .sidebar { -webkit-overflow-scrolling: touch; }
        .sidebar-overlay { user-select: none; -webkit-tap-highlight-color: transparent; }
    </style>
        <!-- Sidebar Overlay (Mobile) -->
        <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

        <!-- Sidebar -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-mobile-header lg:hidden">
                <button class="close-sidebar" onclick="toggleSidebar()">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            <div class="sidebar-header">
                <% if (typeof settingsMap !== 'undefined' && settingsMap.site_logo && settingsMap.site_logo.en) { %>
                    <img src="/uploads/<%= settingsMap.site_logo.en %>" style="height:32px; width:auto; border-radius:4px; margin-right:12px; background: white; padding: 2px;">
                <% } else { %>
                    <span class="material-symbols-outlined logo-icon">admin_panel_settings</span>
                <% } %>
                <h2>Bhumij<span>CMS</span></h2>
            </div>
            <nav class="sidebar-nav">
                <a href="/admin" class="nav-item <%= title === 'Dashboard' ? 'active' : '' %>">
                    <span class="material-symbols-outlined">dashboard</span> Dashboard
                </a>
                <a href="/admin/greetings" class="nav-item <%= title === 'Greeting Messages' ? 'active' : '' %>">
                    <span class="material-symbols-outlined">mail</span> Greetings
                </a>
                <a href="/admin/articles" class="nav-item <%= title === 'Articles' ? 'active' : '' %>">
                    <span class="material-symbols-outlined">article</span> Articles
                </a>
                <a href="/admin/members" class="nav-item <%= title === 'Board Members' ? 'active' : '' %>">
                    <span class="material-symbols-outlined">group</span> Members
                </a>
                <a href="/admin/meetings" class="nav-item <%= title === 'Meetings' ? 'active' : '' %>">
                    <span class="material-symbols-outlined">event</span> Meetings
                </a>
                <a href="/admin/poems" class="nav-item <%= title === 'Poems' ? 'active' : '' %>">
                    <span class="material-symbols-outlined">edit_note</span> Poems
                </a>
                <a href="/admin/gallery" class="nav-item <%= title === 'Gallery' ? 'active' : '' %>">
                    <span class="material-symbols-outlined">photo_library</span> Gallery
                </a>
                <a href="/admin/slides" class="nav-item <%= title === 'Hero Slides' ? 'active' : '' %>">
                    <span class="material-symbols-outlined">slideshow</span> Hero Slides
                </a>
                <a href="/admin/etymology" class="nav-item <%= title === 'Etymology' ? 'active' : '' %>">
                    <span class="material-symbols-outlined">landscape</span> Etymology
                </a>
                <a href="/admin/geography" class="nav-item <%= title === 'Geography (Map)' ? 'active' : '' %>">
                    <span class="material-symbols-outlined">map</span> Geography
                </a>
                <a href="/admin/initiatives" class="nav-item <%= title === 'Government Initiatives' ? 'active' : '' %>">
                    <span class="material-symbols-outlined">gavel</span> Initiatives
                </a>
                <a href="/admin/culture" class="nav-item <%= title === 'Culture & Heritage' ? 'active' : '' %>">
                    <span class="material-symbols-outlined">theater_comedy</span> Culture
                </a>
                <a href="/admin/timeline" class="nav-item <%= title === 'Timeline Events' ? 'active' : '' %>">
                    <span class="material-symbols-outlined">timeline</span> Timeline
                </a>
                <a href="/admin/notable" class="nav-item <%= title === 'Notable People' ? 'active' : '' %>">
                    <span class="material-symbols-outlined">stars</span> Notable People
                </a>
                <a href="/admin/achievements" class="nav-item <%= title === 'Achievements' ? 'active' : '' %>">
                    <span class="material-symbols-outlined">trophy</span> Achievements
                </a>
                <a href="/admin/board-info" class="nav-item <%= title === 'Board Info' ? 'active' : '' %>">
                    <span class="material-symbols-outlined">info</span> Board Info
                </a>
                <a href="/admin/tours" class="nav-item <%= title === 'Tour Activities' ? 'active' : '' %>">
                    <span class="material-symbols-outlined">map</span> Tour Activities
                </a>
                <a href="/admin/settings" class="nav-item <%= title === 'Site Settings' ? 'active' : '' %>">
                    <span class="material-symbols-outlined">settings</span> Settings
                </a>
                <div class="nav-divider"></div>
                <a href="/" class="nav-item" target="_blank">
                    <span class="material-symbols-outlined">language</span> View Site
                </a>
                <a href="/admin/logout" class="nav-item logout">
                    <span class="material-symbols-outlined">logout</span> Logout
                </a>
            </nav>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <header class="top-bar">
                <button class="menu-toggle" onclick="toggleSidebar()">
                    <span class="material-symbols-outlined">menu</span>
                </button>
                <h1 class="page-title"><%= title %></h1>
                <div class="user-info">
                    <span class="material-symbols-outlined">person</span>
                    <span><%= user ? user.fullName : 'Admin' %></span>
                </div>
            </header>
            <div class="content-area">

<script>
    function toggleSidebar() {
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('sidebarOverlay');
        sidebar.classList.toggle('open');
        overlay.classList.toggle('active');
        if (sidebar.classList.contains('open')) {
            document.body.style.overflow = 'hidden';
        } else {
            document.body.style.overflow = '';
        }
    }
</script>
