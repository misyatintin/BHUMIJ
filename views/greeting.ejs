<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Bhumij</title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;900&family=Outfit:wght@300;400;500;600;700&family=Noto+Sans+Bengali:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = { theme: { extend: { colors: { primary: '#2b82ee', 'maya-blue': '#77B5FE', 'sky-blue': '#87CEEB', 'soft-blue': '#f0f9ff', 'dark-slate': '#1e293b' }, fontFamily: { cinzel: ['Cinzel','serif'], outfit: ['Outfit','Noto Sans Bengali','sans-serif'] } } } }
    </script>
    <style>
        body { font-family: 'Outfit', 'Noto Sans Bengali', sans-serif; }
        .cinzel-font { font-family: 'Cinzel', serif; }
        .text-gradient { background: linear-gradient(135deg, #1e3a8a, #2b82ee, #77B5FE); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; }
    </style>
</head>
<body class="bg-white text-dark-slate">

<nav class="fixed top-0 left-0 right-0 z-50 py-4 px-6 md:px-12">
    <div class="max-w-7xl mx-auto flex justify-between items-center bg-white/95 backdrop-blur-xl border border-blue-100/30 rounded-full px-6 py-2 shadow-xl shadow-blue-500/5">
        <a href="/" class="flex items-center gap-2">
            <span class="material-symbols-outlined text-primary text-2xl">temple_hindu</span>
            <span class="cinzel-font text-xl font-bold text-dark-slate"><%= lang === 'bn' ? 'ভূমিজ' : 'BHUMIJ' %></span>
        </a>
        <div class="flex items-center gap-4">
            <a href="/" class="px-4 py-2 text-sm font-medium text-slate-600 hover:text-primary transition-colors"><%= lang === 'bn' ? 'প্রচ্ছদ' : 'Home' %></a>
            <div class="flex items-center bg-slate-100 rounded-full p-1">
                <a href="?lang=en" class="px-3 py-1 rounded-full text-xs font-bold <%= lang === 'en' ? 'bg-primary text-white' : 'text-slate-500' %>">EN</a>
                <a href="?lang=bn" class="px-3 py-1 rounded-full text-xs font-bold <%= lang === 'bn' ? 'bg-primary text-white' : 'text-slate-500' %>">বাং</a>
            </div>
        </div>
    </div>
</nav>

<section class="pt-32 pb-24 px-6">
    <div class="max-w-4xl mx-auto">
        <!-- Header Card -->
        <div class="bg-gradient-to-br from-soft-blue to-white rounded-[40px] border border-blue-100 p-8 md:p-12 mb-12 shadow-xl shadow-blue-500/5">
            <div class="flex flex-col md:flex-row items-center gap-8">
                <% if (greeting.image_path) { %>
                <div class="w-32 h-32 md:w-40 md:h-40 rounded-[30px] overflow-hidden border-4 border-white shadow-2xl flex-shrink-0">
                    <img src="/uploads/<%= greeting.image_path %>" alt="<%= t(greeting, 'person_name', lang) %>" class="w-full h-full object-cover">
                </div>
                <% } else { %>
                <div class="w-32 h-32 md:w-40 md:h-40 rounded-[30px] bg-gradient-to-br from-primary to-maya-blue flex items-center justify-center flex-shrink-0 shadow-2xl">
                    <span class="text-white text-6xl font-black cinzel-font"><%= (t(greeting, 'person_name', lang) || 'N')[0] %></span>
                </div>
                <% } %>
                <div class="text-center md:text-left">
                    <div class="inline-block px-4 py-1.5 bg-primary/10 rounded-full text-[10px] font-bold text-primary uppercase tracking-widest mb-4">
                        <%= lang === 'bn' ? 'শুভেচ্ছা বার্তা' : 'Greeting Message' %>
                    </div>
                    <h1 class="cinzel-font text-3xl md:text-4xl font-black text-dark-slate leading-tight mb-2">
                        <%= t(greeting, 'person_name', lang) %>
                    </h1>
                    <p class="text-primary font-bold text-sm uppercase tracking-widest">
                        <%= t(greeting, 'designation', lang) %>
                    </p>
                </div>
            </div>
        </div>

        <!-- Message Content -->
        <div class="relative bg-white rounded-[40px] border border-slate-100 p-8 md:p-12 shadow-lg">
            <span class="absolute top-6 left-8 text-[120px] text-primary/5 font-serif leading-none pointer-events-none">"</span>
            <div class="relative z-10 text-slate-600 text-lg leading-[2.2] font-light whitespace-pre-line pl-2">
                <%= t(greeting, 'message', lang) %>
            </div>
            <div class="mt-8 pt-6 border-t border-slate-100 flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="w-1 h-8 bg-primary rounded-full"></div>
                    <div>
                        <p class="font-bold text-dark-slate"><%= t(greeting, 'person_name', lang) %></p>
                        <p class="text-primary text-xs font-bold uppercase tracking-widest"><%= t(greeting, 'designation', lang) %></p>
                    </div>
                </div>
                <span class="text-[80px] text-primary/5 font-serif leading-none pointer-events-none">"</span>
            </div>
        </div>

        <!-- Navigation -->
        <div class="mt-12 flex flex-col sm:flex-row justify-between items-center gap-6">
            <a href="/#greetings" class="inline-flex items-center gap-2 text-primary font-bold hover:gap-4 transition-all">
                <span class="material-symbols-outlined">arrow_back</span>
                <%= lang === 'bn' ? 'সকল শুভেচ্ছা বার্তা' : 'All Greeting Messages' %>
            </a>
            <% if (allGreetings && allGreetings.length > 1) { %>
            <div class="flex items-center gap-4">
                <% allGreetings.forEach((g, i) => { %>
                <a href="/greeting/<%= g.id %>" class="w-10 h-10 rounded-full flex items-center justify-center text-xs font-black transition-all <%= g.id === greeting.id ? 'bg-primary text-white shadow-lg shadow-primary/30' : 'bg-slate-100 text-slate-500 hover:bg-primary/10 hover:text-primary' %>">
                    <%= i + 1 %>
                </a>
                <% }) %>
            </div>
            <% } %>
        </div>
    </div>
</section>

</body>
</html>
