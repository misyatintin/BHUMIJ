<%- include('partials/header') %>

<style>
    .masonry { column-count: 1; column-gap: 1.5rem; }
    @media (min-width: 640px) { .masonry { column-count: 2; } }
    @media (min-width: 1024px) { .masonry { column-count: 3; } }
    .masonry-item { break-inside: avoid; margin-bottom: 1.5rem; }
    .gallery-item:hover .gallery-overlay { opacity: 1; transform: translateY(0); }
</style>

<main class="pt-32 pb-20 px-6 max-w-7xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-16">
        <span class="text-primary font-bold text-sm uppercase tracking-[0.3em]"><%= lang === 'bn' ? 'ফটো সংকলন' : 'Visual Archive' %></span>
        <h1 class="cinzel-font text-4xl md:text-5xl font-black text-dark-slate mt-4 mb-4">
            <%= lang === 'bn' ? 'ফটো' : 'Photo' %> <span class="text-gradient"><%= lang === 'bn' ? 'গ্যালারি' : 'Gallery' %></span>
        </h1>
        <div class="w-24 h-1 bg-primary mx-auto rounded-full mb-8"></div>
        <p class="text-slate-500 max-w-2xl mx-auto font-light">
            <%= lang === 'bn' ? 'ভূমিজ সম্প্রদায়ের সংস্কৃতি, ঐতিহ্য এবং বিভিন্ন কার্যক্রমের এক অনন্য সংগ্রহশালা।' : 'A unique collection depicting the culture, heritage, and various activities of the Bhumij community.' %>
        </p>
    </div>

    <!-- Filters -->
    <div class="flex flex-wrap justify-center gap-3 mb-16">
        <button class="filter-btn active px-8 py-2.5 rounded-full text-[10px] font-bold uppercase tracking-widest border transition-all bg-primary text-white border-primary shadow-lg shadow-primary/20" data-filter="all">
            <%= lang === 'bn' ? 'সব' : 'All' %>
        </button>
        <% categories.forEach(c => { %>
            <button class="filter-btn px-8 py-2.5 rounded-full text-[10px] font-bold uppercase tracking-widest border transition-all bg-white text-slate-500 border-slate-200 hover:border-primary hover:text-primary hover:shadow-lg" data-filter="cat-<%= c.id %>">
                <%= t(c, 'name', lang) %>
            </button>
        <% }) %>
    </div>

    <!-- Gallery Grid -->
    <div class="masonry" id="galleryGrid">
        <% images.forEach(img => { %>
            <div class="masonry-item gallery-item group relative overflow-hidden rounded-[32px] bg-white shadow-md hover:shadow-2xl transition-all duration-500 cursor-pointer border border-slate-100" 
                 data-id="<%= img.id %>"
                 data-category="cat-<%= img.category_id %>"
                 data-src="/uploads/<%= img.image_path %>"
                 data-caption="<%= t(img, 'caption', lang) %>"
                 data-cat="<%= lang === 'bn' ? (img.cat_name_bn || img.cat_name_en) : img.cat_name_en %>"
                 onclick="handleGalleryClick(this)">
                
                <img src="/uploads/<%= img.image_path %>" alt="<%= t(img, 'caption', lang) %>" loading="lazy" class="w-full h-auto object-cover transform group-hover:scale-105 transition-transform duration-700">
                
                <div class="gallery-overlay absolute inset-0 bg-gradient-to-t from-dark-slate/90 via-dark-slate/20 to-transparent opacity-0 transform translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-500 flex flex-col justify-end p-8">
                    <span class="text-[10px] font-bold text-primary uppercase tracking-widest mb-2"><%= lang === 'bn' ? (img.cat_name_bn || img.cat_name_en) : img.cat_name_en %></span>
                    <h3 class="text-white font-bold text-lg leading-tight cinzel-font"><%= t(img, 'caption', lang) %></h3>
                    <div class="mt-4 flex items-center text-white/60 text-[10px] font-bold uppercase tracking-widest">
                        <span class="material-symbols-outlined text-sm mr-2">zoom_in</span>
                        <%= lang === 'bn' ? 'বিস্তারিত তথ্য' : 'View Detailed' %>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
</main>

<!-- Lightbox Modal -->
<div id="lightbox" class="fixed inset-0 z-[100] bg-dark-slate/95 hidden backdrop-blur-md flex items-center justify-center p-4 md:p-12 opacity-0 transition-opacity duration-300">
    <button onclick="closeLightbox()" class="absolute top-8 right-8 text-white hover:text-primary transition-colors">
        <span class="material-symbols-outlined text-4xl">close</span>
    </button>
    <div class="max-w-6xl w-full h-full flex flex-col md:flex-row gap-8 items-center justify-center">
        <div class="flex-1 h-full flex items-center justify-center">
            <img id="lightboxImg" src="" alt="" class="max-w-full max-h-[80vh] rounded-[40px] shadow-2xl object-contain ring-1 ring-white/10">
        </div>
        <div class="w-full md:w-96 text-white p-8 bg-white/5 backdrop-blur-xl rounded-[40px] border border-white/10">
            <span id="lightboxCat" class="text-primary font-bold tracking-[0.3em] border-l-4 border-primary pl-4 mb-6 block text-[10px] uppercase"></span>
            <h2 id="lightboxCaption" class="text-3xl font-black cinzel-font mb-6 leading-tight"></h2>
            <div class="h-px bg-white/10 w-full mb-8"></div>
            <p class="text-slate-400 text-sm leading-relaxed mb-8 font-light">
                <%= lang === 'bn' ? 'এই চিত্রটি ভূমিজ ঐতিহ্যের একটি গুরুত্বপূর্ণ দিক তুলে ধরে। এটি আমাদের পূর্বপুরুষদের গভীর সংস্কৃতি ও প্রকৃতির সাথে আমাদের সম্পর্কের প্রতিফলন।' : 'This image showcases a significant aspect of the Bhumij heritage, reflecting our deep culture and connection with nature.' %>
            </p>
            <a id="lightboxDetailLink" href="#" class="flex justify-center px-8 py-4 bg-primary text-white rounded-2xl text-[10px] font-bold uppercase tracking-widest hover:scale-105 hover:shadow-lg hover:shadow-primary/30 transition-all mb-8">
                <%= lang === 'bn' ? 'বিস্তারিত বিবরণ' : 'View Full Details' %>
            </a>
            <div class="flex gap-4">
                <button class="flex-1 py-3 rounded-2xl bg-white/5 hover:bg-white/10 transition-colors flex items-center justify-center gap-2 text-[10px] font-bold uppercase tracking-widest border border-white/5">
                    <span class="material-symbols-outlined text-lg">share</span> Share
                </button>
                <button class="flex-1 py-3 rounded-2xl bg-white/5 hover:bg-white/10 transition-colors flex items-center justify-center gap-2 text-[10px] font-bold uppercase tracking-widest border border-white/5">
                    <span class="material-symbols-outlined text-lg">download</span> Save
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    function handleGalleryClick(el) {
        openLightbox(el.dataset.src, el.dataset.caption, el.dataset.cat, el.dataset.id);
    }

    // Filtering
    const filterBtns = document.querySelectorAll('.filter-btn');
    const galleryItems = document.querySelectorAll('.gallery-item');

    filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            filterBtns.forEach(b => {
                b.classList.remove('bg-primary', 'text-white', 'shadow-lg', 'shadow-primary/20');
                b.classList.add('bg-white', 'text-slate-500');
            });
            btn.classList.add('bg-primary', 'text-white', 'shadow-lg', 'shadow-primary/20');
            btn.classList.remove('bg-white', 'text-slate-500');

            const filter = btn.dataset.filter;
            galleryItems.forEach(item => {
                item.style.opacity = '0';
                item.style.transform = 'scale(0.9)';
                setTimeout(() => {
                    if (filter === 'all' || item.dataset.category === filter) {
                        item.style.display = 'block';
                        setTimeout(() => {
                            item.style.opacity = '1';
                            item.style.transform = 'scale(1)';
                        }, 50);
                    } else {
                        item.style.display = 'none';
                    }
                }, 300);
            });
        });
    });

    // Lightbox
    function openLightbox(src, caption, cat, id) {
        const lb = document.getElementById('lightbox');
        const lbImg = document.getElementById('lightboxImg');
        const lbCap = document.getElementById('lightboxCaption');
        const lbCat = document.getElementById('lightboxCat');
        const lbDetail = document.getElementById('lightboxDetailLink');

        lbImg.src = src;
        lbCap.innerText = caption;
        lbCat.innerText = cat;
        if (lbDetail) lbDetail.href = '/gallery/image/' + id;

        lb.classList.remove('hidden');
        lb.classList.add('flex');
        setTimeout(() => lb.classList.add('opacity-100'), 50);
        document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
        const lb = document.getElementById('lightbox');
        lb.classList.remove('opacity-100');
        setTimeout(() => {
            lb.classList.add('hidden');
            lb.classList.remove('flex');
        }, 300);
        document.body.style.overflow = '';
    }

    // Close on ESC
    window.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeLightbox();
    });
</script>

<%- include('partials/footer') %>


