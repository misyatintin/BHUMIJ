<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;900&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Bengali:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: '#2b82ee',
                        'sky-blue': '#87CEEB',
                        'maya-blue': '#77B5FE',
                        'soft-blue': '#f0f9ff',
                        'dark-slate': '#1e293b',
                    },
                    fontFamily: {
                        cinzel: ['Cinzel', 'serif'],
                        outfit: ['Outfit', 'Noto Sans Bengali', 'sans-serif'],
                    },
                    animation: {
                        'float': 'float 6s ease-in-out infinite',
                        'slow-glow': 'glow 3s infinite alternate',
                    },
                    keyframes: {
                        float: {
                            '0%, 100%': { transform: 'translateY(0)' },
                            '50%': { transform: 'translateY(-10px)' },
                        },
                        glow: {
                            '0%': { textShadow: '0 0 5px rgba(119, 181, 254, 0.2)' },
                            '100%': { textShadow: '0 0 20px rgba(119, 181, 254, 0.6)' },
                        }
                    }
                }
            }
        }
    </script>
    <style>
        html { scroll-behavior: smooth; }
        body { font-family: 'Outfit', 'Noto Sans Bengali', sans-serif; background-color: #ffffff; color: #1e293b; overflow-x: hidden; }
        .cinzel-font { font-family: 'Cinzel', serif; }
        .glass-card { background: rgba(255, 255, 255, 0.8); backdrop-filter: blur(12px); border: 1px solid rgba(119, 181, 254, 0.2); }
        .text-gradient { background: linear-gradient(135deg, #1e3a8a, #2b82ee, #77B5FE); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; }
        .custom-scrollbar::-webkit-scrollbar { width: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: #f1f5f9; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
        .carousel-item { position: absolute; inset: 0; opacity: 0; transition: opacity 1s ease-in-out; }
        .carousel-item.active { opacity: 1; }
        .tilt-card { transition: transform 0.5s cubic-bezier(0.23, 1, 0.32, 1); transform-style: preserve-3d; }
        .tilt-card:hover { transform: rotateX(5deg) rotateY(-5deg) translateZ(20px); }
        .state-active path { fill: #77B5FE !important; stroke: #fff !important; stroke-width: 2px !important; filter: drop-shadow(0 0 10px rgba(119, 181, 254, 0.8)); }
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        .pin-container:hover .pop-tooltip { opacity: 1; }
    </style>
</head>
<body class="custom-scrollbar selection:bg-primary/20">

<!-- Navigation -->
<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 py-4 px-6 md:px-12">
    <div class="max-w-7xl mx-auto flex justify-between items-center bg-white/70 backdrop-blur-xl border border-blue-100/30 rounded-full px-6 py-2 shadow-lg shadow-blue-500/5">
        <a href="#home" class="flex items-center gap-2 group">
            <span class="material-symbols-outlined text-primary text-2xl group-hover:rotate-12 transition-transform">temple_hindu</span>
            <span class="cinzel-font text-xl font-bold tracking-tight text-dark-slate"><%= lang === 'bn' ? 'ভূমিজ' : 'BHUMIJ' %></span>
        </a>
        
        <div class="hidden md:flex items-center gap-1" id="navLinks">
            <a href="#home" class="px-4 py-2 text-sm font-medium text-slate-600 hover:text-primary transition-colors"><%= lang === 'bn' ? 'প্রচ্ছদ' : 'Home' %></a>
            <a href="#etymology" class="px-4 py-2 text-sm font-medium text-slate-600 hover:text-primary transition-colors"><%= lang === 'bn' ? 'ব্যুৎপত্তি' : 'Etymology' %></a>
            <a href="#geography" class="px-4 py-2 text-sm font-medium text-slate-600 hover:text-primary transition-colors"><%= lang === 'bn' ? 'ভূগোল' : 'Geography' %></a>
            <a href="#culture" class="px-4 py-2 text-sm font-medium text-slate-600 hover:text-primary transition-colors"><%= lang === 'bn' ? 'সংস্কৃতি' : 'Culture' %></a>
            <a href="#history" class="px-4 py-2 text-sm font-medium text-slate-600 hover:text-primary transition-colors"><%= lang === 'bn' ? 'সময়রেখা' : 'Timeline' %></a>
            <a href="#people" class="px-4 py-2 text-sm font-medium text-slate-600 hover:text-primary transition-colors"><%= lang === 'bn' ? 'ব্যক্তিত্ব' : 'Notable' %></a>
            <a href="#articles" class="px-4 py-2 text-sm font-medium text-slate-600 hover:text-primary transition-colors"><%= lang === 'bn' ? 'প্রবন্ধ' : 'Articles' %></a>
            <a href="#gallery" class="px-4 py-2 text-sm font-medium text-slate-600 hover:text-primary transition-colors"><%= lang === 'bn' ? 'গ্যালারি' : 'Gallery' %></a>
            <a href="#members" class="px-4 py-2 text-sm font-medium text-slate-600 hover:text-primary transition-colors"><%= lang === 'bn' ? 'সদস্য' : 'Members' %></a>
        </div>

        <div class="flex items-center gap-3">
            <!-- Language Switch -->
            <div class="flex items-center bg-slate-100 rounded-full p-1">
                <a href="?lang=en" class="px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-widest transition-all <%= lang === 'en' ? 'bg-primary text-white shadow-md shadow-primary/20' : 'text-slate-500 hover:text-primary' %>">EN</a>
                <a href="?lang=bn" class="px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-widest transition-all <%= lang === 'bn' ? 'bg-primary text-white shadow-md shadow-primary/20' : 'text-slate-500 hover:text-primary' %>">বাং</a>
            </div>
            <button id="menuBtn" class="md:hidden flex p-2 text-slate-600">
                <span class="material-symbols-outlined">menu</span>
            </button>
        </div>
    </div>
</nav>

<!-- Hero Section -->
<section id="home" class="relative h-screen flex items-center justify-center overflow-hidden">
    <div id="heroCarousel" class="absolute inset-0 z-0">
        <% if (heroSlides.length) { %>
            <% heroSlides.forEach((slide, i) => { %>
            <div class="carousel-item <%= i === 0 ? 'active' : '' %> bg-cover bg-center" style="background-image: linear-gradient(to right, rgba(255,255,255,0.9), rgba(255,255,255,0.2)), url('/uploads/<%= slide.image_path %>')"></div>
            <% }) %>
        <% } else { %>
            <div class="carousel-item active" style="background: linear-gradient(135deg, #f0f9ff, #e0f2fe, #f0f9ff);"></div>
        <% } %>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 text-center lg:text-left w-full">
        <div class="max-w-3xl space-y-8">
            <div class="inline-flex items-center gap-2 px-4 py-2 bg-blue-50 border border-blue-100 rounded-full text-primary text-xs font-bold tracking-[.3em] uppercase">
                <span class="flex h-2 w-2 rounded-full bg-primary animate-pulse"></span>
                <%= lang === 'bn' ? (settingsMap.volume_info?.bn || settingsMap.volume_info?.en || '') : (settingsMap.volume_info?.en || '') %>
            </div>
            
            <h1 class="cinzel-font text-6xl md:text-9xl font-black leading-[0.9] text-dark-slate tracking-tighter">
                <% if (lang === 'bn') { %>
                    ভূমিজ
                <% } else { %>
                    BHUMIJ
                <% } %>
            </h1>
            
            <p class="text-slate-600 text-lg md:text-xl font-light leading-relaxed max-w-2xl">
                <%= lang === 'bn' ? (settingsMap.site_subtitle?.bn || '') : (settingsMap.site_subtitle?.en || '') %>
            </p>
            
            <div class="flex flex-wrap gap-6 justify-center lg:justify-start pt-4">
                <a href="#greetings" class="px-10 py-5 bg-primary text-white font-bold rounded-2xl hover:scale-105 hover:shadow-2xl hover:shadow-primary/30 transition-all flex items-center gap-3 group">
                    <%= lang === 'bn' ? 'পড়ুন' : 'Read More' %>
                    <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
                </a>
                <a href="#gallery" class="flex items-center gap-3 text-dark-slate font-bold uppercase tracking-widest text-sm hover:text-primary transition-colors group">
                    <span class="material-symbols-outlined text-4xl text-primary group-hover:scale-110 transition-transform">photo_library</span>
                    <%= lang === 'bn' ? 'গ্যালারি দেখুন' : 'View Gallery' %>
                </a>
            </div>
        </div>
    </div>

    <!-- Carousel Indicators -->
    <div class="absolute bottom-10 right-12 flex flex-col gap-4 z-20">
        <div class="w-1.5 h-12 bg-slate-200 rounded-full overflow-hidden">
            <div id="carouselProgress" class="w-full h-0 bg-primary transition-all duration-100 ease-linear"></div>
        </div>
    </div>
</section>

<!-- Stats Bar -->
<section class="py-12 px-6">
    <div class="max-w-7xl mx-auto bg-slate-50 border border-slate-100 rounded-[40px] p-10 grid grid-cols-1 md:grid-cols-3 gap-12 text-center shadow-inner">
        <div class="space-y-2">
            <div class="text-4xl lg:text-5xl font-black cinzel-font text-primary stat-num" data-target="<%= members.length %>">0</div>
            <div class="text-xs font-bold uppercase tracking-widest text-slate-400"><%= lang === 'bn' ? 'বোর্ড সদস্য' : 'Board Members' %></div>
        </div>
        <div class="space-y-2 border-y md:border-y-0 md:border-x border-slate-200 py-8 md:py-0">
            <div class="text-4xl lg:text-5xl font-black cinzel-font text-maya-blue stat-num" data-target="<%= articles.length %>">0</div>
            <div class="text-xs font-bold uppercase tracking-widest text-slate-400"><%= lang === 'bn' ? 'প্রবন্ধ' : 'Articles' %></div>
        </div>
        <div class="space-y-2">
            <div class="text-4xl lg:text-5xl font-black cinzel-font text-sky-blue stat-num" data-target="<%= poems.length %>">0</div>
            <div class="text-xs font-bold uppercase tracking-widest text-slate-400"><%= lang === 'bn' ? 'কবিতা' : 'Poems' %></div>
        </div>
    </div>
</section>

<!-- Introduction Section -->
<section class="py-24 px-6 bg-white relative">
    <div class="max-w-7xl mx-auto">
        <div class="text-center space-y-4 mb-16">
            <span class="text-primary font-bold text-sm uppercase tracking-[0.3em]"><%= lang === 'bn' ? 'পরিচিতি' : 'About' %></span>
            <h2 class="cinzel-font text-3xl md:text-6xl font-black text-dark-slate"><%= lang === 'bn' ? 'প্রকাশনা' : 'About This' %> <span class="text-gradient"><%= lang === 'bn' ? 'সম্পর্কে' : 'Publication' %></span></h2>
            <div class="w-24 h-1 bg-primary mx-auto rounded-full"></div>
        </div>
        <div class="max-w-3xl mx-auto text-center">
            <p class="text-slate-600 text-lg leading-relaxed font-light">
                <%= lang === 'bn' ? (settingsMap.introduction_bn?.bn || settingsMap.introduction_en?.en || '') : (settingsMap.introduction_en?.en || '') %>
            </p>
        </div>
    </div>
</section>

<!-- Etymology Section -->
<% if (etymologyCards && etymologyCards.length) { %>
<section id="etymology" class="py-24 px-6 bg-white relative">
    <div class="max-w-7xl mx-auto">
        <div class="text-center space-y-4 mb-20">
            <span class="text-primary font-bold text-sm uppercase tracking-[0.3em]"><%= lang === 'bn' ? 'উৎপত্তি' : 'Origins' %></span>
            <h2 class="cinzel-font text-3xl md:text-6xl font-black text-dark-slate"><%= lang === 'bn' ? 'ব্যুৎপত্তি ও' : 'Etymology &' %> <span class="text-gradient"><%= lang === 'bn' ? 'অর্থ' : 'Meaning' %></span></h2>
            <div class="w-24 h-1 bg-primary mx-auto rounded-full"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <% etymologyCards.forEach((c, i) => { %>
            <div class="p-10 <%= i === 1 ? 'bg-white border border-slate-100 shadow-xl shadow-slate-200/50 scale-105' : 'bg-soft-blue/30 border border-blue-50' %> rounded-[40px] hover:shadow-2xl hover:shadow-blue-500/10 transition-all group">
                <div class="w-16 h-16 <%= i === 1 ? 'bg-primary' : 'bg-white' %> rounded-2xl flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform mb-8">
                    <span class="material-symbols-outlined <%= i === 1 ? 'text-white' : 'text-primary' %> text-3xl"><%= c.icon %></span>
                </div>
                <h3 class="cinzel-font text-2xl font-bold text-dark-slate mb-4"><%= t(c, 'title', lang) %></h3>
                <p class="text-slate-600 leading-relaxed font-light"><%= t(c, 'content', lang) %></p>
            </div>
            <% }) %>
        </div>
    </div>
</section>
<% } %>

<!-- Geographic Core Section -->
<% if (geoStates && geoStates.length) { %>
<section id="geography" class="py-32 px-6 bg-slate-50 relative overflow-hidden">
    <div class="max-w-7xl mx-auto">
        <div class="flex flex-col mb-20 space-y-4">
            <span class="text-primary font-bold text-sm uppercase tracking-[0.4em]"><%= lang === 'bn' ? 'আঞ্চলিক উত্তরাধিকার' : 'Territorial Legacy' %></span>
            <h2 class="cinzel-font text-4xl md:text-6xl font-black text-dark-slate"><%= lang === 'bn' ? 'ভৌগোলিক' : 'Geographic' %> <span class="text-gradient"><%= lang === 'bn' ? 'কেন্দ্র' : 'Core' %></span></h2>
            <div class="w-24 h-1.5 bg-primary rounded-full"></div>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">
            <div class="lg:col-span-7 relative group w-full">
                <div class="relative bg-white p-6 md:p-12 rounded-[40px] md:rounded-[60px] shadow-2xl border border-blue-50 overflow-hidden">
                    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_rgba(119,181,254,0.08)_0%,_transparent_75%)] pointer-events-none"></div>
                    <div id="mapWrapper" class="relative z-10 filter drop-shadow-2xl max-w-full flex-grow flex items-center justify-center">
                        <svg viewBox="0 0 800 650" class="w-full max-h-[500px] h-auto transition-transform duration-1000 group-hover:scale-[1.02]">
                            <!-- Professional Detailed Map of East India (Jharkhand, WB, OR, BR, CH) -->
                            <g class="map-layers opacity-40">
                                <!-- Base Region Context (Simplified but accurate relative positions) -->
                                <path d="M220 180 L350 140 L450 150 L580 120 L680 150 L750 250 L730 400 L650 500 L500 580 L300 560 L180 430 L160 300 Z" fill="#f8fafc" stroke="#94a3b8" stroke-width="1" stroke-dasharray="4 4"/>
                                
                                <!-- State Boundaries (Simulated Professional Detail) -->
                                <path d="M300 250 Q 320 200 380 180 T 450 200 T 500 280 T 420 350 T 320 320 Z" fill="rgba(43, 130, 238, 0.05)" stroke="#2b82ee" stroke-width="0.5" id="path-jh"/>
                                <path d="M480 220 Q 520 200 600 220 T 650 300 T 550 450 T 480 350 Z" fill="rgba(43, 130, 238, 0.02)" stroke="#2b82ee" stroke-width="0.5" id="path-wb"/>
                                <path d="M250 350 Q 300 380 350 500 T 450 550 T 520 500 T 400 400 Z" fill="rgba(43, 130, 238, 0.02)" stroke="#2b82ee" stroke-width="0.5" id="path-or"/>
                            </g>
                            
                            <% 
                            // Precise Projection Logic for East India
                            // Min/Max Lat/Lng bounded to Jharkhand, WB, Odisha, NE
                            const minLat = 17, maxLat = 28;
                            const minLng = 81, maxLng = 95;
                            const svgW = 800, svgH = 650;
                            
                            geoStates.forEach(s => { 
                                let px = s.text_x;
                                let py = s.text_y;
                                
                                // Override with real Lat/Long if provided
                                if (s.latitude && s.longitude) {
                                    px = ((s.longitude - minLng) / (maxLng - minLng)) * svgW;
                                    py = ((maxLat - s.latitude) / (maxLat - minLat)) * svgH;
                                }
                            %>
                            <g id="state-<%= s.state_code %>" class="state-group cursor-pointer transition-all duration-500" onmouseenter="activateState('<%= s.state_code %>')" onmouseleave="deactivateState('<%= s.state_code %>')">
                                <% if (s.svg_path) { %>
                                    <path d="<%= s.svg_path %>" fill="#e2e8f0" stroke="#334155" stroke-width="1.5" class="transition-colors duration-500 hover:fill-primary/30"/>
                                <% } %>
                                <!-- Pin Positioned by Real Coordinates -->
                                <g class="pin-container">
                                    <circle cx="<%= px %>" cy="<%= py %>" r="8" fill="#2b82ee" class="animate-pulse shadow-lg"/>
                                    <circle cx="<%= px %>" cy="<%= py %>" r="16" fill="none" stroke="#2b82ee" stroke-opacity="0.3" class="animate-ping"/>
                                    
                                    <text x="<%= px %>" y="<%= py - 15 %>" font-size="12" fill="#0f172a" font-weight="900" text-anchor="middle" class="cinzel-font pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity">
                                        <%= s.state_code.toUpperCase() %>
                                    </text>
                                    
                                    <g class="pop-tooltip opacity-0 transition-opacity duration-300 pointer-events-none">
                                        <rect x="<%= px - 45 %>" y="<%= py - 45 %>" width="100" height="25" rx="5" fill="#1e293b"/>
                                        <text x="<%= px %>" y="<%= py - 28 %>" font-size="10" fill="#ffffff" font-weight="700" text-anchor="middle">
                                            <%= lang === 'bn' ? 'জনসংখ্যা' : 'Pop' %>: <%= (lang === 'bn' ? (s.population_bn || s.population) : s.population) || 'N/A' %>
                                        </text>
                                    </g>
                                </g>
                            </g>
                            <% }) %>
                        </svg>
                    </div>
                    <div class="mt-8 lg:absolute lg:bottom-10 lg:left-10 p-6 glass-card rounded-3xl shadow-xl max-w-sm border-blue-100/50 z-20">
                        <div class="flex items-center gap-3 mb-3">
                            <div class="w-2 h-8 bg-primary rounded-full"></div>
                            <h4 id="mapTitle" class="cinzel-font font-bold text-dark-slate text-lg uppercase tracking-widest"><%= lang === 'bn' ? 'পূর্বাঞ্চলীয় কেন্দ্রভূমি' : 'Eastern Heartland' %></h4>
                        </div>
                        <p id="mapDesc" class="text-sm text-slate-500 leading-relaxed font-light mb-4"><%= lang === 'bn' ? 'ভূমিজ উপজাতির প্রধান বসতি করিডোর প্রদর্শনকারী ইন্টারেক্টিভ হেরিটেজ মানচিত্র। অঞ্চলগুলোর উপর হোভার করুন।' : 'Interactive heritage map showcasing the primary settlement corridors of the Bhumij tribe. Hover over regions to explore.' %></p>
                        
                        <div id="mapImgContainer" class="hidden overflow-hidden rounded-2xl border-2 border-primary/10 shadow-lg">
                            <img id="mapInfoImg" src="" class="w-full h-32 object-cover">
                        </div>
                    </div>
                </div>
            </div>
            <div class="lg:col-span-5 grid grid-cols-1 sm:grid-cols-2 gap-6 md:gap-8 perspective-1000">
                <% geoStates.forEach((s, i) => { %>
                <div id="card-<%= s.state_code %>" class="tilt-card group relative h-[280px] md:h-[320px] rounded-[40px] overflow-hidden shadow-xl border border-white hover:border-primary/20 transition-all cursor-pointer <%= i % 2 !== 0 ? 'mt-0 sm:mt-12' : '' %>" onmouseenter="activateState('<%= s.state_code %>')" onmouseleave="deactivateState('<%= s.state_code %>')">
                    <% if (s.image_path) { %>
                    <img src="/uploads/<%= s.image_path %>" class="absolute inset-0 w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700">
                    <% } else { %>
                    <div class="absolute inset-0 bg-gradient-to-br from-primary/20 to-maya-blue/40"></div>
                    <% } %>
                    <div class="absolute inset-x-0 bottom-0 h-2/3 bg-gradient-to-t from-dark-slate/90 to-transparent"></div>
                    <div class="absolute bottom-6 left-8 z-10">
                        <h3 class="cinzel-font text-2xl font-black text-white"><%= t(s, 'name', lang) %></h3>
                        <p class="text-maya-blue text-[10px] font-black uppercase tracking-widest mt-1"><%= t(s, 'subtitle', lang) %></p>
                    </div>
                </div>
                <% }) %>
            </div>
        </div>
    </div>
</section>
<% } %>

<!-- Government Initiatives Section -->
<% if (initiatives && initiatives.length) { %>
<section class="py-24 px-6 bg-white">
    <div class="max-w-7xl mx-auto">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-16">
            <div class="space-y-4">
                <span class="text-primary font-bold text-sm uppercase tracking-[0.3em]"><%= lang === 'bn' ? 'ক্ষমতায়ন' : 'Empowerment' %></span>
                <h2 class="cinzel-font text-3xl md:text-5xl font-black text-dark-slate"><%= lang === 'bn' ? 'সরকারি' : 'Government' %> <span class="text-gradient"><%= lang === 'bn' ? 'উদ্যোগ' : 'Initiatives' %></span></h2>
            </div>
            <p class="max-w-md text-slate-500 font-light italic"><%= lang === 'bn' ? 'ভূমিজ সম্প্রদায়কে রক্ষা, সংরক্ষণ ও ক্ষমতায়নের জন্য নীতি ও কর্মসূচি।' : 'Policies and programs designed to protect, preserve, and empower the Bhumij community.' %></p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
            <% initiatives.forEach(n => { %>
            <div class="p-8 bg-slate-50 border border-slate-100 rounded-[40px] hover:bg-white hover:shadow-2xl hover:shadow-primary/10 hover:border-primary/20 transition-all group">
                <div class="w-14 h-14 bg-primary/10 rounded-2xl flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-white transition-all mb-6">
                    <span class="material-symbols-outlined"><%= n.icon %></span>
                </div>
                <h3 class="text-xl font-bold text-dark-slate mb-3 group-hover:text-primary transition-colors"><%= t(n, 'title', lang) %></h3>
