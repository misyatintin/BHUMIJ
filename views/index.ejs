<script>
    // Hero Carousel
    let currentSlide = 0;
    const slides = document.querySelectorAll('.carousel-item');
    const count = slides.length;
    const progress = document.getElementById('carouselProgress');
    
    function nextSlide() {
        if (count <= 1) return;
        slides[currentSlide].classList.remove('active');
        currentSlide = (currentSlide + 1) % count;
        slides[currentSlide].classList.add('active');
        resetProgress();
    }

    function resetProgress() {
        if (!progress) return;
        progress.style.transition = 'none';
        progress.style.height = '0%';
        setTimeout(() => {
            progress.style.transition = 'height 5s linear';
            progress.style.height = '100%';
        }, 50);
    }

    if (count > 1) {
        setInterval(nextSlide, 5000);
        resetProgress();
    }

    // Stats Counter
    const stats = document.querySelectorAll('.stat-num');
    const statsObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                const target = parseInt(entry.target.getAttribute('data-target'));
                let current = 0;
                const increment = Math.max(target / 50, 1);
                const timer = setInterval(() => {
                    current += increment;
                    if (current >= target) {
                        entry.target.innerText = target.toLocaleString();
                        clearInterval(timer);
                    } else {
                        entry.target.innerText = Math.floor(current).toLocaleString();
                    }
                }, 30);
                statsObserver.unobserve(entry.target);
            }
        });
    }, { threshold: 0.5 });
    stats.forEach(stat => statsObserver.observe(stat));

    // Gallery Auto-scroll
    const galleryGrid = document.getElementById('galleryGrid');
    let scrollInterval;
    const startAutoScroll = () => {
        scrollInterval = setInterval(() => {
            if (galleryGrid.scrollLeft + galleryGrid.offsetWidth >= galleryGrid.scrollWidth) {
                galleryGrid.scrollTo({ left: 0, behavior: 'smooth' });
            } else {
                galleryGrid.scrollBy({ left: 340, behavior: 'smooth' });
            }
        }, 3000);
    };
    const stopAutoScroll = () => clearInterval(scrollInterval);
    
    if (galleryGrid) {
        startAutoScroll();
        galleryGrid.addEventListener('mouseenter', stopAutoScroll);
        galleryGrid.addEventListener('mouseleave', startAutoScroll);
    }
</script>

<!-- Map Data (Hidden for JS ingestion) -->
<div id="stateDataMap" style="display:none;" data-json='<%- JSON.stringify(geoStates.reduce((acc, s) => { acc[s.state_code] = { title: lang === "bn" ? (s.name_bn || s.name_en) : s.name_en, desc: lang === "bn" ? (s.description_bn || s.description_en) : s.description_en, img: s.image_path, pop: s.population, lat: s.latitude, lng: s.longitude }; return acc; }, {})) %>'></div>

<script>
    // Map Interactions
    const stateDataEl = document.getElementById('stateDataMap');
    const stateData = stateDataEl ? JSON.parse(stateDataEl.dataset.json) : {};

    function activateState(id) {
        document.querySelectorAll('.state-group').forEach(el => el.classList.remove('state-active'));
        const stateEl = document.getElementById('state-' + id);
        if (stateEl) stateEl.classList.add('state-active');
        document.querySelectorAll('.tilt-card').forEach(el => el.classList.remove('ring-4', 'ring-primary/20', 'scale-105'));
        const card = document.getElementById('card-' + id);
        if (card) { 
            card.classList.add('ring-4', 'ring-primary/20', 'scale-105'); 
            card.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
        }
        if (stateData[id]) {
            const mt = document.getElementById('mapTitle');
            const md = document.getElementById('mapDesc');
            const mic = document.getElementById('mapImgContainer');
            const mii = document.getElementById('mapInfoImg');
            
            if (mt) mt.innerText = stateData[id].title;
            if (md) md.innerText = stateData[id].desc;
            
            if (mic && mii && stateData[id].img) {
                mii.src = '/uploads/' + stateData[id].img;
                mic.classList.remove('hidden');
            } else if (mic) {
                mic.classList.add('hidden');
            }
        }
    }
    function deactivateState(id) {}

    // Gallery Filter
    document.querySelectorAll('.gallery-filter').forEach(btn => {
        btn.addEventListener('click', function() {
            document.querySelectorAll('.gallery-filter').forEach(b => {
                b.classList.remove('bg-primary', 'text-white', 'border-primary');
                b.classList.add('bg-white', 'text-slate-500', 'border-slate-200');
            });
            this.classList.remove('bg-white', 'text-slate-500', 'border-slate-200');
            this.classList.add('bg-primary', 'text-white', 'border-primary');
            
            const filter = this.dataset.filter;
            document.querySelectorAll('.gallery-img').forEach(img => {
                if (filter === 'all' || img.dataset.category === filter) {
                    img.style.display = '';
                } else {
                    img.style.display = 'none';
                }
            });
        });
    });

    // Smooth Scroll
    document.querySelectorAll('a[href^="#"]').forEach(a => {
        a.addEventListener('click', function(e) {
            e.preventDefault();
            const target = document.querySelector(this.getAttribute('href'));
            if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
    });

    // Navbar Scroll
    window.onscroll = () => {
        const nav = document.getElementById('navbar');
        const el = nav.querySelector('.max-w-7xl');
        if (window.scrollY > 100) {
            el.classList.add('shadow-xl', 'bg-white/95');
            el.classList.remove('bg-white/70');
        } else {
            el.classList.remove('shadow-xl', 'bg-white/95');
            el.classList.add('bg-white/70');
        }
    };

    // Mobile Menu
    const menuBtn = document.getElementById('menuBtn');
    const mobileMenu = document.createElement('div');
    mobileMenu.id = 'mobileMenu';
    mobileMenu.className = 'hidden fixed inset-0 z-[60] bg-white flex flex-col items-center justify-center gap-8';
    mobileMenu.innerHTML = `
        <button id="closeMenu" class="absolute top-10 right-10 text-slate-600"><span class="material-symbols-outlined text-4xl">close</span></button>
        <a href="#home" class="cinzel-font text-3xl font-bold"><%= lang === 'bn' ? 'প্রচ্ছদ' : 'Home' %></a>
        <a href="#etymology" class="cinzel-font text-3xl font-bold"><%= lang === 'bn' ? 'ব্যুৎপত্তি' : 'Etymology' %></a>
        <a href="#geography" class="cinzel-font text-3xl font-bold"><%= lang === 'bn' ? 'ভূগোল' : 'Geography' %></a>
        <a href="#culture" class="cinzel-font text-3xl font-bold"><%= lang === 'bn' ? 'সংস্কৃতি' : 'Culture' %></a>
        <a href="#history" class="cinzel-font text-3xl font-bold"><%= lang === 'bn' ? 'সময়রেখা' : 'Timeline' %></a>
        <a href="#people" class="cinzel-font text-3xl font-bold"><%= lang === 'bn' ? 'ব্যক্তিত্ব' : 'Notable' %></a>
        <a href="#articles" class="cinzel-font text-3xl font-bold"><%= lang === 'bn' ? 'প্রবন্ধ' : 'Articles' %></a>
        <a href="#gallery" class="cinzel-font text-3xl font-bold"><%= lang === 'bn' ? 'গ্যালারি' : 'Gallery' %></a>
        <a href="#members" class="cinzel-font text-3xl font-bold"><%= lang === 'bn' ? 'সদস্য' : 'Members' %></a>
    `;
    document.body.appendChild(mobileMenu);
    if (menuBtn) {
        menuBtn.onclick = () => mobileMenu.classList.remove('hidden');
        document.getElementById('closeMenu').onclick = () => mobileMenu.classList.add('hidden');
        mobileMenu.querySelectorAll('a').forEach(link => link.onclick = () => mobileMenu.classList.add('hidden'));
    }
</script>
</body>
</html>
