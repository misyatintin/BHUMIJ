<%- include('partials/header') %>


<!-- Hero Section -->
<section id="home" class="relative h-screen flex items-center justify-center overflow-hidden">
    <div id="heroCarousel" class="absolute inset-0 z-0">
        <% if (heroSlides.length) { %>
            <% heroSlides.forEach((slide, i) => { %>
            <div class="carousel-item <%= i === 0 ? 'active' : '' %> bg-cover bg-center" style="background-image: linear-gradient(to right, rgba(255,255,255,0.9), rgba(255,255,255,0.2)), url('/uploads/<%= slide.image_path %>')"></div>
            <% }) %>
        <% } else { %>
            <div class="carousel-item active" style="background: linear-gradient(135deg, #f0f9ff, #e0f2fe, #f0f9ff);"></div>
        <% } %>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 text-center lg:text-left w-full">
        <div class="max-w-3xl space-y-8">
            <div class="inline-flex items-center gap-2 px-4 py-2 bg-blue-50 border border-blue-100 rounded-full text-primary text-xs font-bold tracking-[.3em] uppercase">
                <span class="flex h-2 w-2 rounded-full bg-primary animate-pulse"></span>
                <%= lang === 'bn' ? (settingsMap.volume_info?.bn || settingsMap.volume_info?.en || '') : (settingsMap.volume_info?.en || '') %>
            </div>
            
            <h1 class="cinzel-font text-6xl md:text-9xl font-black leading-[0.9] text-dark-slate tracking-tighter">
                <% if (lang === 'bn') { %>
                    ভূমিজ
                <% } else { %>
                    BHUMIJ
                <% } %>
            </h1>
            
            <p class="text-slate-600 text-lg md:text-xl font-light leading-relaxed max-w-2xl">
                <%= lang === 'bn' ? (settingsMap.site_subtitle?.bn || '') : (settingsMap.site_subtitle?.en || '') %>
            </p>
            
            <div class="flex flex-wrap gap-6 justify-center lg:justify-start pt-4">
                <a href="#greetings" class="px-10 py-5 bg-primary text-white font-bold rounded-2xl hover:scale-105 hover:shadow-2xl hover:shadow-primary/30 transition-all flex items-center gap-3 group">
                    <%= lang === 'bn' ? 'পড়ুন' : 'Read More' %>
                    <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
                </a>
                <a href="#gallery" class="flex items-center gap-3 text-dark-slate font-bold uppercase tracking-widest text-sm hover:text-primary transition-colors group">
                    <span class="material-symbols-outlined text-4xl text-primary group-hover:scale-110 transition-transform">photo_library</span>
                    <%= lang === 'bn' ? 'গ্যালারি দেখুন' : 'View Gallery' %>
                </a>
            </div>
        </div>
    </div>

    <!-- Carousel Indicators -->
    <div class="absolute bottom-10 right-12 flex flex-col gap-4 z-20">
        <div class="w-1.5 h-12 bg-slate-200 rounded-full overflow-hidden">
            <div id="carouselProgress" class="w-full h-0 bg-primary transition-all duration-100 ease-linear"></div>
        </div>
    </div>
</section>

<!-- Stats Bar -->
<section class="py-12 px-6 -mt-20 relative z-20">
    <div class="max-w-7xl mx-auto bg-white border border-slate-100/50 rounded-[40px] p-10 grid grid-cols-1 md:grid-cols-3 gap-12 text-center shadow-2xl shadow-indigo-500/10 backdrop-blur-sm">
        <div class="space-y-2 group">
            <div class="text-4xl lg:text-7xl font-black cinzel-font text-gradient stat-num" data-target="<%= members.length %>">0</div>
            <div class="text-[10px] font-black uppercase tracking-[0.3em] text-slate-400 group-hover:text-primary transition-colors"><%= lang === 'bn' ? 'বোর্ড সদস্য' : 'Board Members' %></div>
        </div>
        <div class="space-y-2 border-y md:border-y-0 md:border-x border-slate-100 py-8 md:py-0 group">
            <div class="text-4xl lg:text-7xl font-black cinzel-font text-gradient stat-num" data-target="<%= articles.length %>">0</div>
            <div class="text-[10px] font-black uppercase tracking-[0.3em] text-slate-400 group-hover:text-secondary transition-colors"><%= lang === 'bn' ? 'প্রবন্ধ' : 'Articles' %></div>
        </div>
        <div class="space-y-2 group">
            <div class="text-4xl lg:text-7xl font-black cinzel-font text-gradient stat-num" data-target="<%= poems.length %>">0</div>
            <div class="text-[10px] font-black uppercase tracking-[0.3em] text-slate-400 group-hover:text-accent transition-colors"><%= lang === 'bn' ? 'কবিতা' : 'Poems' %></div>
        </div>
    </div>
</section>

<!-- Introduction Section -->
<section class="py-24 px-6 bg-white relative">
    <div class="max-w-7xl mx-auto">
        <div class="text-center space-y-4 mb-16">
            <span class="text-primary font-bold text-sm uppercase tracking-[0.3em]"><%= lang === 'bn' ? 'পরিচিতি' : 'About' %></span>
            <h2 class="cinzel-font text-3xl md:text-6xl font-black text-dark-slate"><%= lang === 'bn' ? 'প্রকাশনা' : 'About This' %> <span class="text-gradient"><%= lang === 'bn' ? 'সম্পর্কে' : 'Publication' %></span></h2>
            <div class="w-24 h-1 bg-primary mx-auto rounded-full"></div>
        </div>
        <div class="max-w-3xl mx-auto text-center">
            <p class="text-slate-600 text-lg leading-relaxed font-light">
                <%= lang === 'bn' ? (settingsMap.introduction_bn?.bn || settingsMap.introduction_en?.en || '') : (settingsMap.introduction_en?.en || '') %>
            </p>
        </div>
    </div>
</section>

<!-- Etymology Section -->
<% if (etymologyCards && etymologyCards.length) { %>
<section id="etymology" class="py-24 px-6 bg-white relative">
    <div class="max-w-7xl mx-auto">
        <div class="text-center space-y-4 mb-20">
            <span class="text-primary font-bold text-sm uppercase tracking-[0.3em]"><%= lang === 'bn' ? 'উৎপত্তি' : 'Origins' %></span>
            <h2 class="cinzel-font text-3xl md:text-6xl font-black text-dark-slate"><%= lang === 'bn' ? 'ব্যুৎপত্তি ও' : 'Etymology &' %> <span class="text-gradient"><%= lang === 'bn' ? 'অর্থ' : 'Meaning' %></span></h2>
            <div class="w-24 h-1 bg-primary mx-auto rounded-full"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <% etymologyCards.forEach((c, i) => { %>
            <div class="p-10 <%= i === 1 ? 'bg-white border border-slate-100 shadow-xl shadow-slate-200/50 scale-105' : 'bg-soft-blue/30 border border-blue-50' %> rounded-[40px] hover:shadow-2xl hover:shadow-blue-500/10 transition-all group">
                <div class="w-16 h-16 <%= i === 1 ? 'bg-primary' : 'bg-white' %> rounded-2xl flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform mb-8">
                    <span class="material-symbols-outlined <%= i === 1 ? 'text-white' : 'text-primary' %> text-3xl"><%= c.icon %></span>
                </div>
                <h3 class="cinzel-font text-2xl font-bold text-dark-slate mb-4"><%= t(c, 'title', lang) %></h3>
                <p class="text-slate-600 leading-relaxed font-light"><%= t(c, 'content', lang) %></p>
            </div>
            <% }) %>
        </div>
    </div>
</section>
<% } %>

<!-- Geographic Core Section -->
<% if (geoStates && geoStates.length) { %>
<!-- Geography Section -->
<section id="geography" class="py-32 px-6 bg-slate-50/50 relative overflow-hidden">
    <div class="absolute top-0 right-0 w-1/2 h-full bg-indigo-100/30 -skew-x-12 translate-x-1/2 pointer-events-none"></div>
    <div class="max-w-7xl mx-auto relative z-10">
        <div class="flex flex-col mb-20 space-y-4">
            <span class="text-primary font-bold text-sm uppercase tracking-[0.4em]"><%= lang === 'bn' ? 'আঞ্চলিক উত্তরাধিকার' : 'Territorial Legacy' %></span>
            <h2 class="cinzel-font text-4xl md:text-6xl font-black text-dark-slate"><%= lang === 'bn' ? 'ভৌগোলিক' : 'Geographic' %> <span class="text-gradient"><%= lang === 'bn' ? 'কেন্দ্র' : 'Core' %></span></h2>
            <div class="w-24 h-1.5 bg-primary rounded-full"></div>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">
            <div class="lg:col-span-7 relative group w-full">
                <div class="relative bg-white p-6 md:p-12 rounded-[40px] md:rounded-[60px] shadow-2xl border border-blue-50 overflow-hidden">
                    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_rgba(119,181,254,0.08)_0%,_transparent_75%)] pointer-events-none"></div>
                    <div id="mapWrapper" class="relative z-10 glass-card rounded-[40px] overflow-hidden border-8 border-white p-4 h-[500px] w-full shadow-2xl transition-all duration-700 hover:scale-[1.01]">
                        <div id="geoRealMap" class="w-full h-full rounded-[20px] shadow-inner relative z-10"></div>
                        <div class="absolute top-8 left-8 z-[20] flex flex-col gap-2">
                            <button onclick="changeMapStyle('streets')" class="p-3 bg-white/90 hover:bg-primary hover:text-white rounded-xl shadow-lg shadow-black/10 backdrop-blur-md transition-all flex items-center justify-center group">
                                <span class="material-symbols-outlined text-sm">map</span>
                            </button>
                            <button onclick="changeMapStyle('satellite')" class="p-3 bg-white/90 hover:bg-primary hover:text-white rounded-xl shadow-lg shadow-black/10 backdrop-blur-md transition-all flex items-center justify-center group">
                                <span class="material-symbols-outlined text-sm">satellite_alt</span>
                            </button>
                        </div>
                    </div>
                    <div id="mapInfoCard" class="opacity-0 translate-y-4 pointer-events-none mt-8 lg:absolute lg:bottom-10 lg:left-10 p-6 glass-card rounded-3xl shadow-xl max-w-sm border-white/40 z-30 min-h-[160px] flex flex-col justify-center transition-all duration-500">
                        <div class="flex items-center gap-3 mb-3">
                            <div class="w-2 h-8 bg-primary rounded-full"></div>
                            <h4 id="mapTitle" class="cinzel-font font-bold text-dark-slate text-lg uppercase tracking-widest"><%= lang === 'bn' ? 'পূর্বাঞ্চলীয় কেন্দ্রভূমি' : 'Eastern Heartland' %></h4>
                        </div>
                        <p id="mapDesc" class="text-sm text-slate-500 leading-relaxed font-light mb-4"><%= lang === 'bn' ? 'ভূমিজ উপজাতির প্রধান বসতি করিডোর প্রদর্শনকারী ইন্টারেক্টিভ হেরিটেজ মানচিত্র। অঞ্চলগুলোর উপর হোভার করুন।' : 'Interactive heritage map showcasing the primary settlement corridors of the Bhumij tribe. Hover over regions to explore.' %></p>
                        
                        <div class="flex items-center gap-2 mb-4">
                            <span class="text-[10px] font-black uppercase tracking-widest text-primary px-3 py-1 bg-primary/10 rounded-full">
                                <%= lang === 'bn' ? 'জনসংখ্যা' : 'Population' %>: <span id="mapPop">--</span>
                            </span>
                        </div>

                        <div id="mapImgContainer" class="hidden overflow-hidden rounded-2xl border-2 border-primary/10 shadow-lg mt-auto">
                            <img id="mapInfoImg" src="" class="w-full h-32 object-contain bg-slate-50">
                        </div>
                    </div>
                </div>
            </div>
            <div class="lg:col-span-5 grid grid-cols-1 sm:grid-cols-2 gap-6 md:gap-8 perspective-1000">
                <% geoStates.forEach((s, i) => { %>
                <div id="card-<%= s.state_code %>" class="tilt-card group relative h-[280px] md:h-[320px] rounded-[40px] overflow-hidden shadow-xl border border-white hover:border-primary/20 transition-all cursor-pointer" onmouseenter="activateState('<%= s.state_code %>', false)" onclick="activateState('<%= s.state_code %>', false)" onmouseleave="deactivateState('<%= s.state_code %>')">
                    <% if (s.image_path) { %>
                    <img src="/uploads/<%= s.image_path %>" class="absolute inset-0 w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700">
                    <% } else { %>
                    <div class="absolute inset-0 bg-gradient-to-br from-primary/20 to-maya-blue/40"></div>
                    <% } %>
                    <div class="absolute inset-x-0 bottom-0 h-2/3 bg-gradient-to-t from-dark-slate/90 to-transparent"></div>
                    <div class="absolute bottom-6 left-8 z-10">
                        <h3 class="cinzel-font text-2xl font-black text-white"><%= t(s, 'name', lang) %></h3>
                        <p class="text-maya-blue text-[10px] font-black uppercase tracking-widest mt-1"><%= t(s, 'subtitle', lang) %></p>
                    </div>
                </div>
                <% }) %>
            </div>
        </div>
    </div>
</section>
<% } %>

<!-- Government Initiatives Section -->
<% if (initiatives && initiatives.length) { %>
<section class="py-24 px-6 bg-white">
    <div class="max-w-7xl mx-auto">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-16">
            <div class="space-y-4">
                <span class="text-primary font-bold text-sm uppercase tracking-[0.3em]"><%= lang === 'bn' ? 'ক্ষমতায়ন' : 'Empowerment' %></span>
                <h2 class="cinzel-font text-3xl md:text-5xl font-black text-dark-slate"><%= lang === 'bn' ? 'সরকারি' : 'Government' %> <span class="text-gradient"><%= lang === 'bn' ? 'উদ্যোগ' : 'Initiatives' %></span></h2>
            </div>
            <p class="max-w-md text-slate-500 font-light italic"><%= lang === 'bn' ? 'ভূমিজ সম্প্রদায়কে রক্ষা, সংরক্ষণ ও ক্ষমতায়নের জন্য নীতি ও কর্মসূচি।' : 'Policies and programs designed to protect, preserve, and empower the Bhumij community.' %></p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
            <% initiatives.forEach(n => { %>
            <div class="p-8 bg-slate-50 border border-slate-100 rounded-[40px] hover:bg-white hover:shadow-2xl hover:shadow-primary/10 hover:border-primary/20 transition-all group">
                <div class="w-14 h-14 bg-primary/10 rounded-2xl flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-white transition-all mb-6">
                    <span class="material-symbols-outlined"><%= n.icon %></span>
                </div>
                <h3 class="text-xl font-bold text-dark-slate mb-3 group-hover:text-primary transition-colors"><%= t(n, 'title', lang) %></h3>
                <p class="text-slate-500 text-sm leading-relaxed mb-6"><%= t(n, 'content', lang) %></p>
                <% if (n.features_en || n.features_bn) { %>
                <ul class="space-y-2">
                    <% const features = (lang === 'bn' && n.features_bn ? n.features_bn : n.features_en || '').split('|'); %>
                    <% features.forEach(f => { %>
                    <li class="flex items-center gap-2 text-xs font-medium text-slate-600"><span class="w-1.5 h-1.5 rounded-full bg-primary/40"></span> <%= f.trim() %></li>
                    <% }) %>
                </ul>
                <% } %>
            </div>
            <% }) %>
        </div>
    </div>
</section>
<% } %>

<!-- Culture & Heritage Section -->
<% if (cultureCards && cultureCards.length) { %>
<section id="culture" class="py-24 px-6 bg-soft-blue/20">
    <div class="max-w-7xl mx-auto">
        <div class="text-center space-y-4 mb-20">
            <span class="text-primary font-bold text-sm uppercase tracking-[0.3em]"><%= lang === 'bn' ? 'আধ্যাত্মিক ও সামাজিক' : 'Spiritual & Social' %></span>
            <h2 class="cinzel-font text-3xl md:text-6xl font-black text-dark-slate"><%= lang === 'bn' ? 'সংস্কৃতি ও' : 'Culture &' %> <span class="text-gradient"><%= lang === 'bn' ? 'ঐতিহ্য' : 'Heritage' %></span></h2>
            <div class="w-24 h-1 bg-primary mx-auto rounded-full"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
            <% cultureCards.forEach(c => { %>
            <div class="bg-white rounded-[40px] overflow-hidden shadow-xl shadow-blue-500/5 group">
                <% if (c.image_url) { %>
                <div class="h-48 overflow-hidden relative">
                    <img src="<%= c.image_url %>" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                    <div class="absolute inset-x-0 bottom-0 h-2 bg-<%= c.color || 'primary' %>"></div>
                </div>
                <% } else { %>
                <div class="h-3 bg-gradient-to-r from-primary via-maya-blue to-sky-blue"></div>
                <% } %>
                <div class="p-8">
                    <div class="flex items-center gap-3 mb-4">
                        <span class="material-symbols-outlined text-<%= c.color || 'primary' %>"><%= c.icon %></span>
                        <h3 class="cinzel-font text-xl font-bold text-dark-slate tracking-wide"><%= t(c, 'title', lang) %></h3>
                    </div>
                    <p class="text-slate-500 text-sm leading-relaxed"><%= t(c, 'content', lang) %></p>
                </div>
            </div>
            <% }) %>
        </div>
    </div>
</section>
<% } %>

<!-- Historical Timeline Section -->
<% if (timelineEvents && timelineEvents.length) { %>
<section id="history" class="py-24 px-6 bg-white overflow-hidden">
    <div class="max-w-4xl mx-auto">
        <div class="text-center space-y-4 mb-20">
            <span class="text-primary font-bold text-sm uppercase tracking-[0.3em]"><%= lang === 'bn' ? 'যুগান্তর' : 'Ages Passed' %></span>
            <h2 class="cinzel-font text-3xl md:text-5xl font-black text-dark-slate"><%= lang === 'bn' ? 'ঐতিহাসিক' : 'Historical' %> <span class="text-gradient"><%= lang === 'bn' ? 'সময়রেখা' : 'Timeline' %></span></h2>
        </div>
        <div class="relative space-y-12">
            <div class="absolute left-[20px] md:left-1/2 top-0 bottom-0 w-1 bg-gradient-to-b from-primary via-maya-blue to-soft-blue rounded-full"></div>
            <% timelineEvents.forEach((e, i) => { %>
            <div class="relative flex flex-col <%= i % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse' %> items-start md:items-center justify-between group">
                <div class="hidden md:block w-[45%] <%= i % 2 === 0 ? 'text-right' : 'text-left' %> bg-slate-50 p-6 rounded-3xl border border-slate-100 opacity-60 group-hover:opacity-100 transition-all shadow-sm">
                    <p class="text-slate-500 italic text-sm"><%= t(e, 'description', lang) %></p>
                </div>
                <div class="absolute left-[-2px] md:left-1/2 -translate-x-1/2 w-11 h-11 bg-white border-4 <%= i === 0 ? 'border-primary' : i === 1 ? 'border-maya-blue' : i === 2 ? 'border-primary' : 'border-sky-blue' %> rounded-full z-10 flex items-center justify-center shadow-lg group-hover:scale-110 transition-all">
                    <span class="text-[10px] font-black <%= i === 0 ? 'text-primary' : i === 1 ? 'text-maya-blue' : i === 2 ? 'text-primary' : 'text-sky-blue' %> uppercase"><%= e.period_code %></span>
                </div>
                <div class="md:w-[45%] pl-14 md:pl-0 space-y-2 <%= i % 2 !== 0 ? 'text-left md:text-right' : '' %>">
                    <div class="inline-block px-3 py-1 bg-blue-50 rounded-full text-[10px] font-bold <%= i === 0 ? 'text-primary' : i === 1 ? 'text-maya-blue' : i === 2 ? 'text-primary' : 'text-sky-blue' %> uppercase tracking-widest"><%= t(e, 'period_label', lang) %></div>
                    <h3 class="cinzel-font text-xl font-bold text-dark-slate"><%= t(e, 'title', lang) %></h3>
                    <p class="md:hidden text-slate-500 text-sm"><%= t(e, 'description', lang) %></p>
                </div>
            </div>
            <% }) %>
        </div>
    </div>
</section>
<% } %>

<!-- Notable People Section -->
<% if (notablePeople && notablePeople.length) { %>
<section id="people" class="py-24 px-6 bg-slate-50">
    <div class="max-w-7xl mx-auto">
        <div class="text-center space-y-4 mb-20">
            <span class="text-primary font-bold text-sm uppercase tracking-[0.3em]"><%= lang === 'bn' ? 'অমর নেতৃবৃন্দ' : 'Eternal Leaders' %></span>
            <h2 class="cinzel-font text-3xl md:text-6xl font-black text-dark-slate"><%= lang === 'bn' ? 'উল্লেখযোগ্য' : 'Notable' %> <span class="text-gradient"><%= lang === 'bn' ? 'ব্যক্তিত্ব' : 'People' %></span></h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
            <% notablePeople.forEach(p => { %>
            <div class="p-8 bg-white rounded-[40px] shadow-sm hover:shadow-2xl transition-all text-center border border-slate-100 group">
                <div class="w-32 h-32 mx-auto rounded-full overflow-hidden border-4 border-blue-50 shadow-lg group-hover:scale-105 transition-transform mb-6 relative">
                    <% if (p.image_path) { %>
                    <img src="/uploads/<%= p.image_path %>" class="w-full h-full object-cover">
                    <% } else { %>
                    <div class="w-full h-full bg-gradient-to-br from-primary to-maya-blue flex items-center justify-center">
                        <span class="text-white text-4xl font-black cinzel-font"><%= (t(p, 'name', lang) || 'N')[0] %></span>
                    </div>
                    <% } %>
                </div>
                <h3 class="cinzel-font text-xl font-bold text-dark-slate"><%= t(p, 'name', lang) %></h3>
                <p class="text-primary text-[10px] font-black uppercase tracking-widest mt-1 mb-3"><%= t(p, 'title', lang) %></p>
                <p class="text-slate-400 text-xs leading-relaxed italic"><%= t(p, 'description', lang) %></p>
            </div>
            <% }) %>
        </div>
    </div>
</section>
<% } %>
<% if (greetings.length) { %>
<section id="greetings" class="py-24 px-6 bg-gradient-to-br from-indigo-50 to-blue-50">
    <div class="max-w-7xl mx-auto">
        <div class="text-center space-y-4 mb-20">
            <span class="text-primary font-bold text-sm uppercase tracking-[0.3em]"><%= lang === 'bn' ? 'শুভেচ্ছা বার্তা' : 'Messages' %></span>
            <h2 class="cinzel-font text-3xl md:text-6xl font-black text-dark-slate"><%= lang === 'bn' ? 'শুভেচ্ছা' : 'Greeting' %> <span class="text-gradient"><%= lang === 'bn' ? 'বার্তা' : 'Messages' %></span></h2>
            <div class="w-24 h-1 bg-primary mx-auto rounded-full"></div>
