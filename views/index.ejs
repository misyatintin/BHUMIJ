<div id="stateDataMap" style="display:none;" data-json='<%- JSON.stringify(geoStates.reduce((acc, s) => { acc[s.state_code] = { title: lang === "bn" ? (s.name_bn || s.name_en) : s.name_en, desc: lang === "bn" ? (s.description_bn || s.description_en) : s.description_en, img: s.image_path, pop: s.population, lat: s.latitude, lng: s.longitude }; return acc; }, {})) %>'></div>

<script>
    // Hero Carousel
    let currentSlide = 0;
    const slides = document.querySelectorAll('.carousel-item');
    const count = slides.length;
    const progress = document.getElementById('carouselProgress');
    
    function nextSlide() {
        if (count <= 1) return;
        slides[currentSlide].classList.remove('active');
        currentSlide = (currentSlide + 1) % count;
        slides[currentSlide].classList.add('active');
        resetProgress();
    }

    function resetProgress() {
        if (!progress) return;
        progress.style.transition = 'none';
        progress.style.height = '0%';
        setTimeout(() => {
            progress.style.transition = 'height 3s linear';
            progress.style.height = '100%';
        }, 50);
    }

    if (count > 1) {
        setInterval(nextSlide, 3000);
        resetProgress();
    }

    // Stats Counter
    const stats = document.querySelectorAll('.stat-num');
    const statsObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                const target = parseInt(entry.target.getAttribute('data-target'));
                let current = 0;
                const increment = Math.max(target / 50, 1);
                const timer = setInterval(() => {
                    current += increment;
                    if (current >= target) {
                        entry.target.innerText = target.toLocaleString();
                        clearInterval(timer);
                    } else {
                        entry.target.innerText = Math.floor(current).toLocaleString();
                    }
                }, 30);
                statsObserver.unobserve(entry.target);
            }
        });
    }, { threshold: 0.5 });
    stats.forEach(stat => statsObserver.observe(stat));

    const galleryGrid = document.getElementById('galleryGrid');
    let scrollInterval;
    const startAutoScroll = () => {
        stopAutoScroll(); 
        scrollInterval = setInterval(() => {
            if (!galleryGrid) return;
            if (galleryGrid.scrollLeft + galleryGrid.offsetWidth >= galleryGrid.scrollWidth - 10) {
                galleryGrid.scrollTo({ left: 0, behavior: 'smooth' });
            } else {
                galleryGrid.scrollBy({ left: 340, behavior: 'smooth' });
            }
        }, 2000);
    };
    const stopAutoScroll = () => {
        if (scrollInterval) clearInterval(scrollInterval);
    };
    function deactivateState(id) {
        const micard = document.getElementById('mapInfoCard');
        if (micard) {
            micard.classList.add('opacity-0', 'translate-y-4');
        }
        document.querySelectorAll('.tilt-card').forEach(el => el.classList.remove('ring-4', 'ring-primary/20', 'scale-105'));
        // Reset all markers
        document.querySelectorAll('.custom-marker > div').forEach(el => {
            el.classList.remove('bg-red-500', 'border-red-500', 'scale-125');
            el.classList.add('bg-primary/20', 'border-primary');
            if (el.querySelector('div')) {
                el.querySelector('div').classList.remove('bg-red-500');
                el.querySelector('div').classList.add('bg-primary');
            }
        });
    }

    const galleryProgress = document.getElementById('galleryProgress');
    const updateProgress = () => {
        if (!galleryGrid || !galleryProgress) return;
        const maxScroll = galleryGrid.scrollWidth - galleryGrid.offsetWidth;
        const percentage = (galleryGrid.scrollLeft / maxScroll) * 100;
        galleryProgress.style.width = percentage + '%';
    };

    if (galleryGrid) {
        startAutoScroll();
        galleryGrid.addEventListener('mouseenter', stopAutoScroll);
        galleryGrid.addEventListener('mouseleave', startAutoScroll);
        galleryGrid.addEventListener('scroll', updateProgress);
    }

    // Map Interactions
    const stateDataEl = document.getElementById('stateDataMap');
    const stateData = stateDataEl ? JSON.parse(stateDataEl.dataset.json) : {};

    // Initialize Real Map (Using Google Maps Tiles)
    let map;
    let markers = {};
    const layers = {
        streets: L.tileLayer('http://{s}.google.com/vt/lyrs=m&x={x}&y={y}&z={z}', { maxZoom: 20, subdomains:['mt0','mt1','mt2','mt3'] }),
        satellite: L.tileLayer('http://{s}.google.com/vt/lyrs=s,h&x={x}&y={y}&z={z}', { maxZoom: 20, subdomains:['mt0','mt1','mt2','mt3'] })
    };

    function initMap() {
        if (!document.getElementById('geoRealMap')) return;
        
        // Center on East India
        map = L.map('geoRealMap', {
            center: [23.5, 87.0],
            zoom: 6,
            layers: [layers.satellite], // Default to Satellite for "Real" look
            zoomControl: false,
            scrollWheelZoom: false
        });

        // Add Zoom Control on Bottom Right
        L.control.zoom({ position: 'bottomright' }).addTo(map);

        // Add Markers from State Data
        Object.keys(stateData).forEach(code => {
            const s = stateData[code];
            if (s.lat && s.lng) {
                const marker = L.marker([s.lat, s.lng], {
                    icon: L.divIcon({
                        className: 'custom-marker',
                        html: `<div id="marker-${code}" class="w-10 h-10 bg-primary/20 backdrop-blur-sm border-2 border-primary rounded-full flex items-center justify-center animate-pulse shadow-lg transition-all"><div class="w-3 h-3 bg-primary rounded-full"></div></div>`
                    })
                }).addTo(map);
                
                marker.on('mouseover', () => activateState(code, false));
                marker.on('mouseout', () => deactivateState(code));
                marker.on('click', () => activateState(code, true));
                markers[code] = marker;
            }
        });
    }

    function changeMapStyle(style) {
        if (layers[style]) {
            Object.values(layers).forEach(layer => map.removeLayer(layer));
            layers[style].addTo(map);
        }
    }

    function activateState(id, shouldFly = true) {
        const markerEl = document.getElementById('marker-' + id);
        
        // Reset all markers
        document.querySelectorAll('.custom-marker > div').forEach(el => {
            el.classList.remove('bg-red-500', 'border-red-500', 'scale-125');
            el.classList.add('bg-primary/20', 'border-primary');
            el.querySelector('div').classList.remove('bg-red-500');
            el.querySelector('div').classList.add('bg-primary');
        });

        if (markerEl) {
            markerEl.classList.remove('bg-primary/20', 'border-primary');
            markerEl.classList.add('bg-red-500', 'border-red-500', 'scale-125');
            markerEl.querySelector('div').classList.remove('bg-primary');
            markerEl.querySelector('div').classList.add('bg-red-500');
        }

        if (shouldFly && stateData[id] && stateData[id].lat) {
            map.flyTo([stateData[id].lat, stateData[id].lng], 8, { duration: 1.5 });
        }

        document.querySelectorAll('.tilt-card').forEach(el => el.classList.remove('ring-4', 'ring-primary/20', 'scale-105'));
        const card = document.getElementById('card-' + id);
        if (card) { 
            card.classList.add('ring-4', 'ring-primary/20', 'scale-105'); 
        }
        
        if (stateData[id]) {
            const mt = document.getElementById('mapTitle');
            const md = document.getElementById('mapDesc');
            const mp = document.getElementById('mapPop');
            const mic = document.getElementById('mapImgContainer');
            const mii = document.getElementById('mapInfoImg');
            const micard = document.getElementById('mapInfoCard');
            
            if (mt) mt.innerText = stateData[id].title;
            if (md) md.innerText = stateData[id].desc;
            if (mp) mp.innerText = stateData[id].pop || '--';
            
            if (mic && mii && stateData[id].img) {
                mii.src = '/uploads/' + stateData[id].img;
                mic.classList.remove('hidden');
            } else if (mic) {
                mic.classList.add('hidden');
            }

            if (micard) {
                micard.classList.remove('opacity-0', 'translate-y-4');
            }
        }
    }

    initMap();

    // Gallery Filter
    document.querySelectorAll('.gallery-filter').forEach(btn => {
        btn.addEventListener('click', function() {
            document.querySelectorAll('.gallery-filter').forEach(b => {
                b.classList.remove('bg-primary', 'text-white', 'border-primary');
                b.classList.add('bg-white', 'text-slate-500', 'border-slate-200');
            });
            this.classList.remove('bg-white', 'text-slate-500', 'border-slate-200');
            this.classList.add('bg-primary', 'text-white', 'border-primary');
            
            const filter = this.dataset.filter;
            document.querySelectorAll('.gallery-img').forEach(img => {
                if (filter === 'all' || img.dataset.category === filter) {
                    img.style.display = '';
                } else {
                    img.style.display = 'none';
                }
            });
        });
    });

    // Smooth Scroll
    document.querySelectorAll('a[href^="#"]').forEach(a => {
        a.addEventListener('click', function(e) {
            const href = this.getAttribute('href');
            if (href === '#') return;
            e.preventDefault();
            const target = document.querySelector(href);
            if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
    });
</script>
<%- include('partials/footer') %>
